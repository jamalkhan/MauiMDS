<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:MauiMds.Controls"
             xmlns:markdown="clr-namespace:MauiMds.Features.Markdown"
             x:Class="MauiMds.Views.ViewerHostView">
    <Border BackgroundColor="{AppThemeBinding Light=#F7F2E8, Dark=#2D2E30}"
            Stroke="{AppThemeBinding Light=#D5CCBC, Dark=#45474B}"
            StrokeThickness="1"
            Padding="30,26"
            Margin="0,-13,0,0"
            StrokeShape="RoundRectangle 0,0,18,18">
        <Grid>
            <markdown:MarkdownView x:Name="ReaderView"
                                   IsVisible="{Binding IsReaderMode}"
                                   IsRenderingEnabled="{Binding IsReaderMode}"
                                   InitialRenderLineCount="{Binding InitialViewerRenderLineCount}"
                                   Blocks="{Binding ParsedBlocks}"
                                   SourceFilePath="{Binding FilePath}" />

            <Border IsVisible="{Binding IsViewerLoading}"
                    InputTransparent="True"
                    BackgroundColor="{AppThemeBinding Light=#F7F2E8, Dark=#2D2E30}"
                    StrokeThickness="0"
                    Padding="0"
                    Margin="0"
                    StrokeShape="RoundRectangle 14">
                <Grid RowDefinitions="Auto,*"
                      RowSpacing="14">
                    <HorizontalStackLayout Spacing="12">
                        <ActivityIndicator IsRunning="{Binding IsViewerLoading}"
                                           Color="{AppThemeBinding Light=#6F6250, Dark=#E6DED2}"
                                           VerticalOptions="Center" />
                        <Label Text="Preparing markdown preview..."
                               VerticalTextAlignment="Center"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#4A443C, Dark=#E6DED2}" />
                    </HorizontalStackLayout>

                    <ScrollView Grid.Row="1">
                        <Label Text="{Binding ViewerLoadingPreviewText}"
                               FontFamily="Courier New"
                               FontSize="14"
                               LineBreakMode="WordWrap"
                               TextColor="{AppThemeBinding Light=#4A443C, Dark=#E6DED2}" />
                    </ScrollView>
                </Grid>
            </Border>

            <Border IsVisible="{Binding IsViewerLoading}"
                    InputTransparent="True"
                    BackgroundColor="{AppThemeBinding Light=#F7F2E8CC, Dark=#2D2E30CC}"
                    StrokeThickness="0"
                    Padding="18,14"
                    StrokeShape="RoundRectangle 14"
                    VerticalOptions="End"
                    HorizontalOptions="End"
                    Margin="0,0,0,6">
                <HorizontalStackLayout Spacing="12">
                    <ActivityIndicator IsRunning="{Binding IsViewerLoading}"
                                       Color="{AppThemeBinding Light=#6F6250, Dark=#E6DED2}"
                                       VerticalOptions="Center" />
                    <Label Text="Loading preview..."
                           VerticalTextAlignment="Center"
                           FontSize="13"
                           TextColor="{AppThemeBinding Light=#4A443C, Dark=#E6DED2}" />
                </HorizontalStackLayout>
            </Border>

            <controls:MarkdownSyntaxEditorView x:Name="TextEditor"
                                               IsVisible="{Binding IsTextEditorMode}"
                                               Text="{Binding EditorText, Mode=TwoWay}"
                                               Placeholder="Edit Markdown here..."
                                               IsSyntaxHighlightingEnabled="False" />

            <controls:VisualEditorView x:Name="VisualEditor"
                                       IsVisible="{Binding IsVisualEditorMode}"
                                         Blocks="{Binding ParsedBlocks}"
                                         Text="{Binding EditorText, Mode=TwoWay}" />
        </Grid>
    </Border>
</ContentView>
