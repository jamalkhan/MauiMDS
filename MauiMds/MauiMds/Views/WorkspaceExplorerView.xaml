<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:MauiMds.Controls"
             x:Class="MauiMds.Views.WorkspaceExplorerView"
             x:Name="RootExplorerView">
    <Grid x:Name="WorkspacePaneHost"
          WidthRequest="260"
          ColumnDefinitions="*,10">
        <Border x:Name="WorkspacePanelBorder"
                Grid.Column="0"
                BackgroundColor="{AppThemeBinding Light=#F4F0E6, Dark=#2A2B2D}"
                Stroke="{AppThemeBinding Light=#D8D0C2, Dark=#45474B}"
                StrokeThickness="1"
                Padding="12"
                StrokeShape="RoundRectangle 18">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*"
                  RowSpacing="10">
                <Button Text="Open Folder"
                        Command="{Binding OpenFolderCommand}"
                        Padding="12,10"
                        BackgroundColor="{AppThemeBinding Light=#DDD3BF, Dark=#3F3D39}"
                        TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#F3EDE2}" />

                <Grid Grid.Row="1"
                      ColumnDefinitions="Auto,Auto,*"
                      ColumnSpacing="8">
                    <Button Text="Up"
                            Command="{Binding NavigateUpWorkspaceCommand}"
                            Padding="12,8"
                            BackgroundColor="{AppThemeBinding Light=#E8E0CF, Dark=#3A3835}"
                            TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#F3EDE2}" />
                    <Button Grid.Column="1"
                            Text="Set Workspace"
                            Command="{Binding SetWorkspaceFolderToCurrentCommand}"
                            Padding="12,8"
                            BackgroundColor="{AppThemeBinding Light=#D4DDCF, Dark=#344136}"
                            TextColor="{AppThemeBinding Light=#182018, Dark=#F0F6EF}" />
                    <Entry Grid.Column="2"
                           Placeholder="Search workspace"
                           Text="{Binding WorkspaceSearchText}"
                           ClearButtonVisibility="WhileEditing"
                           BackgroundColor="{AppThemeBinding Light=#FBF8F2, Dark=#313234}"
                           TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#F3EDE2}" />
                </Grid>

                <VerticalStackLayout Grid.Row="2"
                                     Spacing="2">
                    <Label Text="Workspace Folder"
                           FontSize="10"
                           TextColor="{AppThemeBinding Light=#7B7469, Dark=#AFA89C}" />
                    <Label Text="{Binding WorkspaceRootPath}"
                           FontSize="11"
                           LineBreakMode="MiddleTruncation"
                           TextColor="{AppThemeBinding Light=#5A544C, Dark=#BFB7AC}" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Row="3"
                                     Spacing="2">
                    <Label Text="Current Folder"
                           FontSize="10"
                           TextColor="{AppThemeBinding Light=#7B7469, Dark=#AFA89C}" />
                    <Label Text="{Binding CurrentWorkspaceFolderDisplay}"
                           FontSize="11"
                           LineBreakMode="MiddleTruncation"
                           TextColor="{AppThemeBinding Light=#3E3A35, Dark=#E1D9CC}" />
                </VerticalStackLayout>

                <Button Grid.Row="4"
                        Text="Create MDS"
                        Command="{Binding CreateMdsCommand}"
                        Padding="12,10"
                        BackgroundColor="{AppThemeBinding Light=#C9D7C5, Dark=#38453A}"
                        TextColor="{AppThemeBinding Light=#152016, Dark=#EFF7EE}" />

                <CollectionView x:Name="WorkspaceCollectionViewControl"
                                Grid.Row="5"
                                ItemsSource="{Binding WorkspaceItems}"
                                SelectionMode="None"
                                VerticalOptions="Fill">
                    <CollectionView.EmptyView>
                        <Label Text="Open a folder to browse markdown files."
                               FontSize="12"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light=#746C61, Dark=#B9B2A8}" />
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="6,4"
                                    Margin="0,1"
                                    StrokeThickness="0"
                                    BackgroundColor="Transparent"
                                    StrokeShape="RoundRectangle 10">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border"
                                                 Binding="{Binding IsSelected}"
                                                 Value="True">
                                        <Setter Property="BackgroundColor"
                                                Value="{AppThemeBinding Light=#E8E0CF, Dark=#393835}" />
                                    </DataTrigger>
                                </Border.Triggers>

                                <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto"
                                      ColumnSpacing="6">
                                    <controls:WorkspaceItemIconView Grid.Column="0"
                                                                    Kind="{Binding ItemIconKind}"
                                                                    VerticalOptions="Center" />

                                    <Grid Grid.Column="1">
                                        <VerticalStackLayout Spacing="1">
                                            <Label Text="{Binding Name}"
                                                   FontSize="12"
                                                   LineBreakMode="MiddleTruncation"
                                                   MaxLines="1"
                                                   VerticalTextAlignment="Center"
                                                   TextColor="{AppThemeBinding Light=#1B1A18, Dark=#F3EDE2}">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label"
                                                                 Binding="{Binding IsRenaming}"
                                                                 Value="True">
                                                        <Setter Property="IsVisible"
                                                                Value="False" />
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>

                                            <Label Text="{Binding SecondaryText}"
                                                   FontSize="10"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="1"
                                                   TextColor="{AppThemeBinding Light=#736C61, Dark=#AEA79C}">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label"
                                                                 Binding="{Binding IsRenaming}"
                                                                 Value="True">
                                                        <Setter Property="IsVisible"
                                                                Value="False" />
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                        </VerticalStackLayout>

                                        <Entry Text="{Binding RenameText}"
                                               FontSize="12"
                                               IsVisible="False"
                                               ClearButtonVisibility="Never"
                                               Loaded="OnWorkspaceRenameEntryLoaded"
                                               Completed="OnWorkspaceRenameCompleted"
                                               Unfocused="OnWorkspaceRenameUnfocused">
                                            <Entry.Triggers>
                                                <DataTrigger TargetType="Entry"
                                                             Binding="{Binding IsRenaming}"
                                                             Value="True">
                                                    <Setter Property="IsVisible"
                                                            Value="True" />
                                                </DataTrigger>
                                            </Entry.Triggers>
                                        </Entry>
                                    </Grid>

                                    <Label Grid.Column="2"
                                           Text="›"
                                           FontSize="16"
                                           VerticalTextAlignment="Center"
                                           HorizontalTextAlignment="Center"
                                           IsVisible="{Binding IsDirectory}"
                                           TextColor="{AppThemeBinding Light=#7A7267, Dark=#BEB6AA}" />

                                    <Button Grid.Column="3"
                                            Text="R"
                                            WidthRequest="22"
                                            HeightRequest="22"
                                            Padding="0"
                                            FontSize="10"
                                            Command="{Binding Source={x:Reference RootExplorerView}, Path=BindingContext.BeginRenameWorkspaceItemCommand}"
                                            CommandParameter="{Binding .}"
                                            IsVisible="{Binding CanRename}"
                                            BackgroundColor="Transparent"
                                            TextColor="{AppThemeBinding Light=#6B6358, Dark=#D4CCBF}" />

                                    <Button Grid.Column="5"
                                            Text="Transcribe"
                                            IsVisible="{Binding IsAudioFile}"
                                            Padding="8,4"
                                            FontSize="10"
                                            Command="{Binding Source={x:Reference RootExplorerView}, Path=BindingContext.TranscribeAudioCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="{AppThemeBinding Light=#3A7DD4, Dark=#2A5DA0}"
                                            TextColor="White" />
                                </Grid>

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={x:Reference RootExplorerView}, Path=BindingContext.SelectWorkspaceItemCommand}"
                                                          CommandParameter="{Binding .}" />
                                    <TapGestureRecognizer NumberOfTapsRequired="2"
                                                          Command="{Binding Source={x:Reference RootExplorerView}, Path=BindingContext.NavigateWorkspaceItemCommand}"
                                                          CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Border>

        <Grid x:Name="WorkspaceResizeHandle"
              Grid.Column="1"
              WidthRequest="12"
              Margin="0,12,0,12"
              VerticalOptions="Fill"
              Opacity="0.94">
            <Border Padding="0"
                    BackgroundColor="{AppThemeBinding Light=#E6DCCB, Dark=#37393D}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 8">
                <VerticalStackLayout Spacing="6"
                                     VerticalOptions="Center"
                                     HorizontalOptions="Center">
                    <BoxView WidthRequest="3" HeightRequest="20" Color="{AppThemeBinding Light=#BDAF97, Dark=#6F7379}" />
                    <BoxView WidthRequest="3" HeightRequest="20" Color="{AppThemeBinding Light=#BDAF97, Dark=#6F7379}" />
                </VerticalStackLayout>
            </Border>
            <Grid.GestureRecognizers>
                <PanGestureRecognizer PanUpdated="OnResizePanUpdated" />
                <PointerGestureRecognizer PointerEntered="OnResizePointerEntered"
                                          PointerExited="OnResizePointerExited" />
            </Grid.GestureRecognizers>
        </Grid>
    </Grid>
</ContentView>
