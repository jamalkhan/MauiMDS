<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiMds.Views.RecordingGroupView">

    <Border BackgroundColor="{AppThemeBinding Light=#EDE8E0CC, Dark=#25242299}"
            Stroke="{AppThemeBinding Light=#D8D0C2, Dark=#474542}"
            StrokeThickness="1"
            Padding="14,10"
            Margin="0,0,0,0"
            StrokeShape="RoundRectangle 14,14,0,0">

        <VerticalStackLayout x:Name="ChipsContainer"
                             Spacing="8" />

    </Border>
</ContentView>
