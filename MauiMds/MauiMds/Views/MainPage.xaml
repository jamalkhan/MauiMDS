<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:MauiMds.Controls"
             xmlns:markdown="clr-namespace:MauiMds.Markdown"
             xmlns:models="clr-namespace:MauiMds.Models"
             x:Class="MauiMds.Views.MainPage"
             x:Name="RootPage"
             BackgroundColor="{AppThemeBinding Light=#E7E4DE, Dark=#232321}">
    <Grid>
        <Grid Padding="28"
              ColumnDefinitions="Auto,Auto,*">
            <Grid x:Name="WorkspacePaneHost"
                  Grid.Column="0"
                  WidthRequest="260"
                  Margin="0,0,12,0"
                  ColumnDefinitions="*,10">
                <Border x:Name="WorkspacePanelBorder"
                        Grid.Column="0"
                        BackgroundColor="{AppThemeBinding Light=#F4F0E6, Dark=#2A2B2D}"
                        Stroke="{AppThemeBinding Light=#D8D0C2, Dark=#45474B}"
                        StrokeThickness="1"
                        Padding="12"
                        StrokeShape="RoundRectangle 18">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*"
                          RowSpacing="10">
                    <Button Text="Open Folder"
                            Command="{Binding OpenFolderCommand}"
                            Padding="12,10"
                            BackgroundColor="{AppThemeBinding Light=#DDD3BF, Dark=#3F3D39}"
                            TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#F3EDE2}" />

                    <Grid Grid.Row="1"
                          ColumnDefinitions="Auto,Auto,*"
                          ColumnSpacing="8">
                        <Button Text="Up"
                                Command="{Binding NavigateUpWorkspaceCommand}"
                                Padding="12,8"
                                BackgroundColor="{AppThemeBinding Light=#E8E0CF, Dark=#3A3835}"
                                TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#F3EDE2}" />
                        <Button Grid.Column="1"
                                Text="Set Workspace"
                                Command="{Binding SetWorkspaceFolderToCurrentCommand}"
                                Padding="12,8"
                                BackgroundColor="{AppThemeBinding Light=#D4DDCF, Dark=#344136}"
                                TextColor="{AppThemeBinding Light=#182018, Dark=#F0F6EF}" />
                        <Entry Grid.Column="2"
                               Placeholder="Search workspace"
                               Text="{Binding WorkspaceSearchText}"
                               ClearButtonVisibility="WhileEditing"
                               BackgroundColor="{AppThemeBinding Light=#FBF8F2, Dark=#313234}"
                               TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#F3EDE2}" />
                    </Grid>

                    <VerticalStackLayout Grid.Row="2"
                                         Spacing="2">
                        <Label Text="Workspace Folder"
                               FontSize="10"
                               TextColor="{AppThemeBinding Light=#7B7469, Dark=#AFA89C}" />
                        <Label Text="{Binding WorkspaceRootPath}"
                               FontSize="11"
                               LineBreakMode="MiddleTruncation"
                               TextColor="{AppThemeBinding Light=#5A544C, Dark=#BFB7AC}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Row="3"
                                         Spacing="2">
                        <Label Text="Current Folder"
                               FontSize="10"
                               TextColor="{AppThemeBinding Light=#7B7469, Dark=#AFA89C}" />
                        <Label Text="{Binding CurrentWorkspaceFolderDisplay}"
                               FontSize="11"
                               LineBreakMode="MiddleTruncation"
                               TextColor="{AppThemeBinding Light=#3E3A35, Dark=#E1D9CC}" />
                    </VerticalStackLayout>

                    <Button Grid.Row="4"
                            Text="Create MDS"
                            Command="{Binding CreateMdsCommand}"
                            Padding="12,10"
                            BackgroundColor="{AppThemeBinding Light=#C9D7C5, Dark=#38453A}"
                            TextColor="{AppThemeBinding Light=#152016, Dark=#EFF7EE}" />

                    <CollectionView x:Name="WorkspaceCollectionView"
                                    Grid.Row="5"
                                    ItemsSource="{Binding WorkspaceItems}"
                                    SelectionMode="None"
                                    VerticalOptions="Fill">
                        <CollectionView.EmptyView>
                            <Label Text="Open a folder to browse markdown files."
                                   FontSize="12"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center"
                                   TextColor="{AppThemeBinding Light=#746C61, Dark=#B9B2A8}" />
                        </CollectionView.EmptyView>

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="6,4"
                                        Margin="0,1"
                                        StrokeThickness="0"
                                        BackgroundColor="Transparent"
                                        StrokeShape="RoundRectangle 10">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding IsSelected}"
                                                     Value="True">
                                            <Setter Property="BackgroundColor"
                                                    Value="{AppThemeBinding Light=#E8E0CF, Dark=#393835}" />
                                        </DataTrigger>
                                    </Border.Triggers>

                                    <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto"
                                          ColumnSpacing="6">
                                        <controls:WorkspaceItemIconView Grid.Column="0"
                                                                        Kind="{Binding ItemIconKind}"
                                                                        VerticalOptions="Center" />

                                        <Grid Grid.Column="1">
                                            <VerticalStackLayout Spacing="1">
                                                <Label Text="{Binding Name}"
                                                       FontSize="12"
                                                       LineBreakMode="MiddleTruncation"
                                                       MaxLines="1"
                                                       VerticalTextAlignment="Center"
                                                       TextColor="{AppThemeBinding Light=#1B1A18, Dark=#F3EDE2}">
                                                    <Label.Triggers>
                                                        <DataTrigger TargetType="Label"
                                                                     Binding="{Binding IsRenaming}"
                                                                     Value="True">
                                                            <Setter Property="IsVisible"
                                                                    Value="False" />
                                                        </DataTrigger>
                                                    </Label.Triggers>
                                                </Label>

                                                <Label Text="{Binding SecondaryText}"
                                                       FontSize="10"
                                                       LineBreakMode="TailTruncation"
                                                       MaxLines="1"
                                                       TextColor="{AppThemeBinding Light=#736C61, Dark=#AEA79C}">
                                                    <Label.Triggers>
                                                        <DataTrigger TargetType="Label"
                                                                     Binding="{Binding IsRenaming}"
                                                                     Value="True">
                                                            <Setter Property="IsVisible"
                                                                    Value="False" />
                                                        </DataTrigger>
                                                    </Label.Triggers>
                                                </Label>
                                            </VerticalStackLayout>

                                            <Entry Text="{Binding RenameText}"
                                                   FontSize="12"
                                                   IsVisible="False"
                                                   ClearButtonVisibility="Never"
                                                   Loaded="OnWorkspaceRenameEntryLoaded"
                                                   Completed="OnWorkspaceRenameCompleted"
                                                   Unfocused="OnWorkspaceRenameUnfocused">
                                                <Entry.Triggers>
                                                    <DataTrigger TargetType="Entry"
                                                                 Binding="{Binding IsRenaming}"
                                                                 Value="True">
                                                        <Setter Property="IsVisible"
                                                                Value="True" />
                                                    </DataTrigger>
                                                </Entry.Triggers>
                                            </Entry>
                                        </Grid>

                                        <Label Grid.Column="2"
                                               Text="›"
                                               FontSize="16"
                                               VerticalTextAlignment="Center"
                                               HorizontalTextAlignment="Center"
                                               IsVisible="{Binding IsDirectory}"
                                               TextColor="{AppThemeBinding Light=#7A7267, Dark=#BEB6AA}" />

                                        <Button Grid.Column="3"
                                                Text="R"
                                                WidthRequest="22"
                                                HeightRequest="22"
                                                Padding="0"
                                                FontSize="10"
                                                Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.BeginRenameWorkspaceItemCommand}"
                                                CommandParameter="{Binding .}"
                                                IsVisible="{Binding CanRename}"
                                                BackgroundColor="Transparent"
                                                TextColor="{AppThemeBinding Light=#6B6358, Dark=#D4CCBF}" />
                                    </Grid>

                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.SelectWorkspaceItemCommand}"
                                                              CommandParameter="{Binding .}" />
                                        <TapGestureRecognizer NumberOfTapsRequired="2"
                                                              Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.NavigateWorkspaceItemCommand}"
                                                              CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    </Grid>
                </Border>

                <Grid x:Name="WorkspaceResizeHandle"
                      Grid.Column="1"
                      WidthRequest="12"
                      Margin="0,12,0,12"
                      VerticalOptions="Fill">
                    <Border Padding="0"
                            BackgroundColor="{AppThemeBinding Light=#E6DCCB, Dark=#37393D}"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 8">
                        <VerticalStackLayout Spacing="6"
                                             VerticalOptions="Center"
                                             HorizontalOptions="Center">
                            <BoxView WidthRequest="3" HeightRequest="20" Color="{AppThemeBinding Light=#BDAF97, Dark=#6F7379}" />
                            <BoxView WidthRequest="3" HeightRequest="20" Color="{AppThemeBinding Light=#BDAF97, Dark=#6F7379}" />
                        </VerticalStackLayout>
                    </Border>
                    <Grid.GestureRecognizers>
                        <PanGestureRecognizer PanUpdated="OnWorkspaceResizePanUpdated" />
                    </Grid.GestureRecognizers>
                </Grid>
            </Grid>

            <Border Grid.Column="1"
                    x:Name="WorkspaceRail"
                    WidthRequest="28"
                    Padding="6,12"
                    Margin="0,0,12,0"
                    VerticalOptions="Fill"
                    BackgroundColor="{AppThemeBinding Light=#DDD3BF, Dark=#343331}"
                    Stroke="{AppThemeBinding Light=#CBBEAA, Dark=#4C4F53}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 14">
                <VerticalStackLayout Spacing="8"
                                     VerticalOptions="Center"
                                     HorizontalOptions="Center">
                    <Label Text="◂"
                           HorizontalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light=#4D463E, Dark=#E7DED2}" />
                    <Label Text="Explorer"
                           Rotation="-90"
                           FontSize="11"
                           HorizontalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light=#4D463E, Dark=#E7DED2}" />
                </VerticalStackLayout>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnWorkspaceRailTapped" />
                </Border.GestureRecognizers>
            </Border>

            <Grid Grid.Column="2"
                  RowDefinitions="Auto,Auto,*">
                <Border Grid.Row="0"
                        BackgroundColor="{AppThemeBinding Light=#F4F0E6, Dark=#2D2C2A}"
                        Stroke="{AppThemeBinding Light=#D8D0C2, Dark=#474542}"
                        StrokeThickness="1"
                        Padding="18,14"
                        Margin="0,0,0,12">
                    <Grid RowDefinitions="Auto,Auto"
                          RowSpacing="14">
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto"
                              ColumnSpacing="16">
                        <Button Text="{Binding WorkspaceToggleLabel}"
                                Command="{Binding ToggleWorkspacePanelCommand}"
                                VerticalOptions="Center"
                                Padding="14,10"
                                BackgroundColor="{AppThemeBinding Light=#E8E0CF, Dark=#3A3835}"
                                TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#F3EDE2}" />

                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="4">
                            <Label x:Name="FileNameLabel"
                                   Text="{Binding FileName}"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#151515, Dark=#F3EDE2}" />
                            <Label x:Name="FilePathLabel"
                                   Text="{Binding HeaderPathDisplay}"
                                   FontSize="13"
                                   LineBreakMode="MiddleTruncation"
                                   TextColor="{AppThemeBinding Light=#53504A, Dark=#B9B2A8}" />
                            <Label Text="{Binding StatusText}"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light=#6A655D, Dark=#BEB7AC}" />
                            <Border IsVisible="{Binding HasInlineError}"
                                    BackgroundColor="{AppThemeBinding Light=#FBE0DD, Dark=#432524}"
                                    StrokeThickness="0"
                                    Padding="12,8"
                                    Margin="0,8,0,0"
                                    StrokeShape="RoundRectangle 12">
                                <Label Text="{Binding InlineErrorMessage}"
                                       FontSize="12"
                                       LineBreakMode="WordWrap"
                                       TextColor="{AppThemeBinding Light=#7D2E28, Dark=#FFE7E4}" />
                            </Border>
                            </VerticalStackLayout>

                            <Button Grid.Column="2"
                                    Text="Open"
                                    Command="{Binding OpenFileCommand}"
                                    VerticalOptions="Center"
                                    Padding="18,10"
                                    BackgroundColor="{AppThemeBinding Light=#DDD3BF, Dark=#3F3D39}"
                                    TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#F3EDE2}" />

                            <Button Grid.Column="3"
                                    Text="Save"
                                    Command="{Binding SaveCommand}"
                                    VerticalOptions="Center"
                                    Padding="18,10"
                                    BackgroundColor="{AppThemeBinding Light=#D4DDCF, Dark=#344136}"
                                    TextColor="{AppThemeBinding Light=#182018, Dark=#F0F6EF}" />

                            <Button Grid.Column="4"
                                    Text="Preferences"
                                    Command="{Binding ShowPreferencesCommand}"
                                    VerticalOptions="Center"
                                    Padding="18,10"
                                    BackgroundColor="{AppThemeBinding Light=#E8E0CF, Dark=#3A3835}"
                                    TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#F3EDE2}" />
                        </Grid>

                        <Grid Grid.Row="1"
                              ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                              ColumnSpacing="10">
                            <Button Text="Viewer"
                                    Command="{Binding SetViewModeCommand}"
                                    CommandParameter="{x:Static models:EditorViewMode.Viewer}"
                                    Padding="14,8">
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button"
                                                 Binding="{Binding IsViewerMode}"
                                                 Value="True">
                                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#1D1D1B, Dark=#F3EDE2}" />
                                        <Setter Property="TextColor" Value="{AppThemeBinding Light=#F7F2E8, Dark=#1D1D1B}" />
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>

                            <Button Grid.Column="1"
                                    Text="Markdown"
                                    Command="{Binding SetViewModeCommand}"
                                    CommandParameter="{x:Static models:EditorViewMode.TextEditor}"
                                    Padding="14,8">
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button"
                                                 Binding="{Binding IsTextEditorMode}"
                                                 Value="True">
                                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#1D1D1B, Dark=#F3EDE2}" />
                                        <Setter Property="TextColor" Value="{AppThemeBinding Light=#F7F2E8, Dark=#1D1D1B}" />
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>

                            <Button Grid.Column="2"
                                    Text="Rich Text"
                                    Command="{Binding SetViewModeCommand}"
                                    CommandParameter="{x:Static models:EditorViewMode.RichTextEditor}"
                                    Padding="14,8">
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button"
                                                 Binding="{Binding IsRichTextEditorMode}"
                                                 Value="True">
                                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#1D1D1B, Dark=#F3EDE2}" />
                                        <Setter Property="TextColor" Value="{AppThemeBinding Light=#F7F2E8, Dark=#1D1D1B}" />
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>

                            <Label Grid.Column="3"
                                   Text="{Binding CurrentViewLabel}"
                                   VerticalTextAlignment="Center"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light=#635D54, Dark=#C7C0B5}" />

                            <Button Grid.Column="4"
                                    Text="New"
                                    Command="{Binding NewDocumentCommand}"
                                    Padding="14,8" />
                            <Button Grid.Column="5"
                                    Text="Save As"
                                    Command="{Binding SaveAsCommand}"
                                    Padding="14,8" />
                            <Button Grid.Column="6"
                                    Text="Revert"
                                    Command="{Binding RevertCommand}"
                                    Padding="14,8" />
                            <Button Grid.Column="7"
                                    Text="Close"
                                    Command="{Binding CloseDocumentCommand}"
                                    Padding="14,8" />
                            <Button Grid.Column="8"
                                    Text="Undo"
                                    Command="{Binding UndoCommand}"
                                    Padding="14,8" />
                            <Button Grid.Column="9"
                                    Text="Redo"
                                    Command="{Binding RedoCommand}"
                                    Padding="14,8" />
                            <Button Grid.Column="10"
                                    Text="Find"
                                    Command="{Binding FindCommand}"
                                    Padding="14,8" />
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        BackgroundColor="{AppThemeBinding Light=#F4F0E6, Dark=#2D2C2A}"
                        Stroke="{AppThemeBinding Light=#D8D0C2, Dark=#474542}"
                        StrokeThickness="1"
                        Padding="18,14"
                        Margin="0,0,0,12"
                        IsVisible="{Binding IsPreferencesVisible}">
                    <Grid ColumnDefinitions="*,Auto"
                          RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                          ColumnSpacing="12"
                          RowSpacing="12">
                        <Label Text="Preferences"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#151515, Dark=#F3EDE2}" />

                        <HorizontalStackLayout Grid.Row="1"
                                               Spacing="12">
                            <Label Text="Autosave"
                                   VerticalTextAlignment="Center"
                                   TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#F3EDE2}" />
                            <Switch IsToggled="{Binding PreferencesAutoSaveEnabled}" />
                            <Label Text="Delay (seconds)"
                                   VerticalTextAlignment="Center"
                                   TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#F3EDE2}" />
                            <Entry WidthRequest="90"
                                   Keyboard="Numeric"
                                   Text="{Binding PreferencesAutoSaveDelaySecondsText}" />
                        </HorizontalStackLayout>

                        <HorizontalStackLayout Grid.Row="2"
                                               Spacing="12">
                            <Label Text="Max Log Size (MB)"
                                   VerticalTextAlignment="Center"
                                   TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#F3EDE2}" />
                            <Entry WidthRequest="90"
                                   Keyboard="Numeric"
                                   Text="{Binding PreferencesMaxLogFileSizeMbText}" />
                            <Label Text="Default is 2 MB"
                                   VerticalTextAlignment="Center"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light=#6A655D, Dark=#BEB7AC}" />
                        </HorizontalStackLayout>

                        <HorizontalStackLayout Grid.Row="3"
                                               Spacing="12">
                            <Label Text="Initial Viewer Lines"
                                   VerticalTextAlignment="Center"
                                   TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#F3EDE2}" />
                            <Entry WidthRequest="90"
                                   Keyboard="Numeric"
                                   Text="{Binding PreferencesInitialViewerRenderLineCountText}" />
                            <Label Text="Default is 20"
                                   VerticalTextAlignment="Center"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light=#6A655D, Dark=#BEB7AC}" />
                        </HorizontalStackLayout>

                        <HorizontalStackLayout Grid.Row="4"
                                               Grid.ColumnSpan="2"
                                               Spacing="10">
                            <Button Text="Save Preferences"
                                    Command="{Binding SavePreferencesCommand}" />
                            <Button Text="Cancel"
                                    Command="{Binding CancelPreferencesCommand}" />
                        </HorizontalStackLayout>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        BackgroundColor="{AppThemeBinding Light=#F7F2E8, Dark=#2D2E30}"
                        Stroke="{AppThemeBinding Light=#D5CCBC, Dark=#45474B}"
                        StrokeThickness="1"
                        Padding="30,26"
                        StrokeShape="RoundRectangle 18">
                    <Grid>
                        <markdown:MarkdownView x:Name="MarkdownViewer"
                                               IsVisible="{Binding IsViewerMode}"
                                               IsRenderingEnabled="{Binding IsViewerMode}"
                                               InitialRenderLineCount="{Binding InitialViewerRenderLineCount}"
                                               Blocks="{Binding ParsedBlocks}"
                                               SourceFilePath="{Binding FilePath}" />

                        <controls:MarkdownSyntaxEditorView x:Name="MarkdownTextEditor"
                                                           IsVisible="{Binding IsEditorMode}"
                                                           Text="{Binding EditorText, Mode=TwoWay}"
                                                           Placeholder="Edit Markdown here..."
                                                           IsSyntaxHighlightingEnabled="False" />

                        <Border IsVisible="{Binding IsRichTextEditorMode}"
                                BackgroundColor="{AppThemeBinding Light=#EFE6D6, Dark=#3A3632}"
                                StrokeThickness="0"
                                Padding="12,10"
                                Margin="0,0,0,12"
                                VerticalOptions="Start"
                                StrokeShape="RoundRectangle 12">
                                <Label Text="Rich text mode is currently stubbed with a plaintext editor. Markdown parsing stays active behind the scenes."
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light=#4A443C, Dark=#E6DED2}" />
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Grid VerticalOptions="End"
              Margin="20,0,20,12"
              RowDefinitions="Auto,Auto">
            <Border x:Name="HistoryTrayBorder"
                    Grid.Row="0"
                    BackgroundColor="{AppThemeBinding Light=#FAF7F0, Dark=#262728}"
                    Stroke="{AppThemeBinding Light=#D5CCBC, Dark=#4B4D50}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 20,20,0,0"
                    Padding="16,14,16,10"
                    HeightRequest="0"
                    IsVisible="False">
                <Grid RowDefinitions="Auto,*"
                      RowSpacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Snackbar History"
                               FontAttributes="Bold"
                               FontSize="16"
                               TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#F3EDE2}" />
                        <Label x:Name="HistoryCountLabel"
                               Grid.Column="1"
                               FontSize="12"
                               VerticalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light=#615A51, Dark=#BFB8AE}" />
                    </Grid>

                    <ScrollView Grid.Row="1">
                        <VerticalStackLayout x:Name="SnackbarHistoryStack"
                                             Spacing="10" />
                    </ScrollView>
                </Grid>

                <Border.GestureRecognizers>
                    <PanGestureRecognizer PanUpdated="OnTrayPanUpdated" />
                </Border.GestureRecognizers>
            </Border>

            <Grid Grid.Row="1"
                  RowDefinitions="Auto,Auto"
                  RowSpacing="8">
                <Border x:Name="SnackbarBorder"
                        BackgroundColor="{AppThemeBinding Light=#F7F2E8, Dark=#2D2E30}"
                        StrokeThickness="0"
                        Padding="14,12"
                        IsVisible="False"
                        StrokeShape="RoundRectangle 18">
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="12">
                        <BoxView x:Name="SnackbarAccent"
                                 WidthRequest="6"
                                 HeightRequest="48"
                                 VerticalOptions="Center"
                                 CornerRadius="3" />

                        <Grid Grid.Column="1"
                              RowDefinitions="Auto,Auto,Auto"
                              RowSpacing="2">
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  ColumnSpacing="10">
                                <Label x:Name="SnackbarLevelLabel"
                                       FontAttributes="Bold"
                                       FontSize="12" />
                                <Label x:Name="SnackbarCategoryLabel"
                                       Grid.Column="1"
                                       FontSize="12"
                                       LineBreakMode="TailTruncation" />
                                <Label x:Name="SnackbarTimeLabel"
                                       Grid.Column="2"
                                       FontSize="11" />
                            </Grid>

                            <Label x:Name="SnackbarMessageLabel"
                                   Grid.Row="1"
                                   FontSize="14"
                                   LineBreakMode="WordWrap"
                                   MaxLines="3" />

                            <Label Grid.Row="2"
                                   Text="Tap to open history"
                                   FontSize="11"
                                   TextColor="{AppThemeBinding Light=#6D655C, Dark=#B7AFA4}" />
                        </Grid>

                        <Button x:Name="SnackbarDismissButton"
                                Grid.Column="2"
                                Text="X"
                                FontSize="12"
                                FontAttributes="Bold"
                                WidthRequest="32"
                                HeightRequest="32"
                                CornerRadius="16"
                                Padding="0"
                                VerticalOptions="Start"
                                Clicked="OnSnackbarDismissClicked" />
                    </Grid>

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSnackbarTapped" />
                    </Border.GestureRecognizers>
                </Border>

                <Border x:Name="TrayHandleBorder"
                        Grid.Row="1"
                        BackgroundColor="{AppThemeBinding Light=#F4F0E6, Dark=#303130}"
                        Stroke="{AppThemeBinding Light=#D8D0C2, Dark=#4A4C4D}"
                        StrokeThickness="1"
                        Padding="16,10"
                        StrokeShape="RoundRectangle 18">
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="12">
                        <BoxView WidthRequest="42"
                                 HeightRequest="4"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Start"
                                 CornerRadius="2"
                                 Color="{AppThemeBinding Light=#A99D8C, Dark=#787268}" />
                        <Label Grid.Column="1"
                               Text="Snackbar"
                               FontAttributes="Bold"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#2A2926, Dark=#EDE6DB}" />
                        <Label x:Name="TrayStateLabel"
                               Grid.Column="2"
                               FontSize="12"
                               VerticalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light=#5A544C, Dark=#BFB7AC}" />
                    </Grid>

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTrayHandleTapped" />
                        <PanGestureRecognizer PanUpdated="OnTrayPanUpdated" />
                    </Border.GestureRecognizers>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
