<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:MauiMds.Models;assembly=MauiMds.Core"
             xmlns:views="clr-namespace:MauiMds.Views"
             xmlns:converters="clr-namespace:MauiMds.Converters"
             x:Class="MauiMds.Views.MainPage"
             BackgroundColor="{AppThemeBinding Light=#E7E4DE, Dark=#232321}">
    <ContentPage.Resources>
        <converters:EnumToBoolConverter x:Key="EnumToBoolConverter" />
    </ContentPage.Resources>
    <Grid>
        <Grid Padding="28"
              ColumnDefinitions="Auto,*">
            <views:WorkspaceExplorerView x:Name="WorkspaceExplorer"
                                         Grid.Column="0"
                                         Margin="0,0,20,0" />

            <Grid Grid.Column="1"
                  RowDefinitions="Auto,Auto,Auto,*,Auto"
                  RowSpacing="12">
                <views:DocumentHeaderView x:Name="DocumentHeader"
                                          Grid.Row="0" />

                <Border Grid.Row="1"
                        BackgroundColor="{AppThemeBinding Light=#F4F0E6, Dark=#2D2C2A}"
                        Stroke="{AppThemeBinding Light=#D8D0C2, Dark=#474542}"
                        StrokeThickness="1"
                        Padding="18,14"
                        StrokeShape="RoundRectangle 18"
                        IsVisible="{Binding IsPreferencesVisible}">
                    <Grid RowDefinitions="Auto,Auto,Auto"
                          RowSpacing="14">

                        <!-- Header row: title + tab buttons -->
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="16">
                            <Label Text="Preferences"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   VerticalTextAlignment="Center"
                                   TextColor="{AppThemeBinding Light=#151515, Dark=#F3EDE2}" />
                            <HorizontalStackLayout Grid.Column="1"
                                                   Spacing="4">
                                <Button Text="General"
                                        FontSize="13"
                                        Padding="14,6"
                                        CornerRadius="8"
                                        Command="{Binding ShowGeneralTabCommand}">
                                    <Button.Triggers>
                                        <DataTrigger TargetType="Button"
                                                     Binding="{Binding IsGeneralTabActive}"
                                                     Value="True">
                                            <Setter Property="BackgroundColor"
                                                    Value="{AppThemeBinding Light=#C8C0B2, Dark=#4A4743}" />
                                            <Setter Property="FontAttributes" Value="Bold" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Button"
                                                     Binding="{Binding IsGeneralTabActive}"
                                                     Value="False">
                                            <Setter Property="BackgroundColor"
                                                    Value="{AppThemeBinding Light=#E0D8CC, Dark=#3A3835}" />
                                            <Setter Property="FontAttributes" Value="None" />
                                        </DataTrigger>
                                    </Button.Triggers>
                                </Button>
                                <Button Text="Keyboard Shortcuts"
                                        FontSize="13"
                                        Padding="14,6"
                                        CornerRadius="8"
                                        Command="{Binding ShowShortcutsTabCommand}">
                                    <Button.Triggers>
                                        <DataTrigger TargetType="Button"
                                                     Binding="{Binding IsShortcutsTabActive}"
                                                     Value="True">
                                            <Setter Property="BackgroundColor"
                                                    Value="{AppThemeBinding Light=#C8C0B2, Dark=#4A4743}" />
                                            <Setter Property="FontAttributes" Value="Bold" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Button"
                                                     Binding="{Binding IsShortcutsTabActive}"
                                                     Value="False">
                                            <Setter Property="BackgroundColor"
                                                    Value="{AppThemeBinding Light=#E0D8CC, Dark=#3A3835}" />
                                            <Setter Property="FontAttributes" Value="None" />
                                        </DataTrigger>
                                    </Button.Triggers>
                                </Button>
                                <Button Text="Transcription"
                                        FontSize="13"
                                        Padding="14,6"
                                        CornerRadius="8"
                                        Command="{Binding ShowTranscriptionTabCommand}">
                                    <Button.Triggers>
                                        <DataTrigger TargetType="Button"
                                                     Binding="{Binding IsTranscriptionTabActive}"
                                                     Value="True">
                                            <Setter Property="BackgroundColor"
                                                    Value="{AppThemeBinding Light=#C8C0B2, Dark=#4A4743}" />
                                            <Setter Property="FontAttributes" Value="Bold" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Button"
                                                     Binding="{Binding IsTranscriptionTabActive}"
                                                     Value="False">
                                            <Setter Property="BackgroundColor"
                                                    Value="{AppThemeBinding Light=#E0D8CC, Dark=#3A3835}" />
                                            <Setter Property="FontAttributes" Value="None" />
                                        </DataTrigger>
                                    </Button.Triggers>
                                </Button>
                            </HorizontalStackLayout>
                        </Grid>

                        <!-- Tab content row -->
                        <Grid Grid.Row="1">
                            <!-- General tab -->
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                                  RowSpacing="12"
                                  IsVisible="{Binding IsGeneralTabActive}">
                                <HorizontalStackLayout Spacing="12">
                                    <Label Text="Autosave"
                                           VerticalTextAlignment="Center"
                                           TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#F3EDE2}" />
                                    <Switch IsToggled="{Binding PreferencesAutoSaveEnabled}" />
                                    <Label Text="Delay (seconds)"
                                           VerticalTextAlignment="Center"
                                           TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#F3EDE2}" />
                                    <Entry WidthRequest="90"
                                           Keyboard="Numeric"
                                           Text="{Binding PreferencesAutoSaveDelaySecondsText}" />
                                </HorizontalStackLayout>

                                <HorizontalStackLayout Grid.Row="1"
                                                       Spacing="12">
                                    <Label Text="Max Log Size (MB)"
                                           VerticalTextAlignment="Center"
                                           TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#F3EDE2}" />
                                    <Entry WidthRequest="90"
                                           Keyboard="Numeric"
                                           Text="{Binding PreferencesMaxLogFileSizeMbText}" />
                                    <Label Text="Default is 2 MB"
                                           VerticalTextAlignment="Center"
                                           FontSize="12"
                                           TextColor="{AppThemeBinding Light=#6A655D, Dark=#BEB7AC}" />
                                </HorizontalStackLayout>

                                <HorizontalStackLayout Grid.Row="2"
                                                       Spacing="12">
                                    <Label Text="Initial Viewer Lines"
                                           VerticalTextAlignment="Center"
                                           TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#F3EDE2}" />
                                    <Entry WidthRequest="90"
                                           Keyboard="Numeric"
                                           Text="{Binding PreferencesInitialViewerRenderLineCountText}" />
                                    <Label Text="Default is 20"
                                           VerticalTextAlignment="Center"
                                           FontSize="12"
                                           TextColor="{AppThemeBinding Light=#6A655D, Dark=#BEB7AC}" />
                                </HorizontalStackLayout>

                                <HorizontalStackLayout Grid.Row="3"
                                                       Spacing="12">
                                    <Label Text="File Log Level"
                                           VerticalTextAlignment="Center"
                                           TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#F3EDE2}" />
                                    <Picker WidthRequest="160"
                                            Title="Log level"
                                            ItemsSource="{Binding AvailableFileLogLevels}"
                                            SelectedItem="{Binding PreferencesFileLogLevelText}" />
                                    <Label Text="Default is Info"
                                           VerticalTextAlignment="Center"
                                           FontSize="12"
                                           TextColor="{AppThemeBinding Light=#6A655D, Dark=#BEB7AC}" />
                                </HorizontalStackLayout>

                                <HorizontalStackLayout Grid.Row="4"
                                                       Spacing="12">
                                    <Label Text="24-Hour Time"
                                           VerticalTextAlignment="Center"
                                           TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#F3EDE2}" />
                                    <Switch IsToggled="{Binding PreferencesUse24HourTime}" />
                                    <Label Text="Default is 12-hour"
                                           VerticalTextAlignment="Center"
                                           FontSize="12"
                                           TextColor="{AppThemeBinding Light=#6A655D, Dark=#BEB7AC}" />
                                </HorizontalStackLayout>

                                <HorizontalStackLayout Grid.Row="5"
                                                       Spacing="12">
                                    <Label Text="Explorer Auto-Refresh (seconds)"
                                           VerticalTextAlignment="Center"
                                           TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#F3EDE2}" />
                                    <Entry WidthRequest="90"
                                           Keyboard="Numeric"
                                           Text="{Binding PreferencesWorkspaceRefreshIntervalSeconds}" />
                                    <Label Text="0 = disabled, default 30"
                                           VerticalTextAlignment="Center"
                                           FontSize="12"
                                           TextColor="{AppThemeBinding Light=#6A655D, Dark=#BEB7AC}" />
                                </HorizontalStackLayout>
                            </Grid>

                            <!-- Keyboard Shortcuts tab -->
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                                  RowSpacing="10"
                                  IsVisible="{Binding IsShortcutsTabActive}">
                                <Label Text="Shortcuts use ⌘ + key. Type a single letter or digit."
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light=#6A655D, Dark=#BEB7AC}" />

                                <Grid Grid.Row="1"
                                      ColumnDefinitions="140,Auto,60"
                                      ColumnSpacing="8">
                                    <Label Text="Heading 1"
                                           VerticalTextAlignment="Center"
                                           TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#F3EDE2}" />
                                    <Label Grid.Column="1"
                                           Text="⌘ +"
                                           VerticalTextAlignment="Center"
                                           FontSize="14"
                                           TextColor="{AppThemeBinding Light=#6A655D, Dark=#BEB7AC}" />
                                    <Entry Grid.Column="2"
                                           MaxLength="1"
                                           HorizontalTextAlignment="Center"
                                           Text="{Binding ShortcutKeyHeader1}" />
                                </Grid>

                                <Grid Grid.Row="2"
                                      ColumnDefinitions="140,Auto,60"
                                      ColumnSpacing="8">
                                    <Label Text="Heading 2"
                                           VerticalTextAlignment="Center"
                                           TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#F3EDE2}" />
                                    <Label Grid.Column="1"
                                           Text="⌘ +"
                                           VerticalTextAlignment="Center"
                                           FontSize="14"
                                           TextColor="{AppThemeBinding Light=#6A655D, Dark=#BEB7AC}" />
                                    <Entry Grid.Column="2"
                                           MaxLength="1"
                                           HorizontalTextAlignment="Center"
                                           Text="{Binding ShortcutKeyHeader2}" />
                                </Grid>

                                <Grid Grid.Row="3"
                                      ColumnDefinitions="140,Auto,60"
                                      ColumnSpacing="8">
                                    <Label Text="Heading 3"
                                           VerticalTextAlignment="Center"
                                           TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#F3EDE2}" />
                                    <Label Grid.Column="1"
                                           Text="⌘ +"
                                           VerticalTextAlignment="Center"
                                           FontSize="14"
                                           TextColor="{AppThemeBinding Light=#6A655D, Dark=#BEB7AC}" />
                                    <Entry Grid.Column="2"
                                           MaxLength="1"
                                           HorizontalTextAlignment="Center"
                                           Text="{Binding ShortcutKeyHeader3}" />
                                </Grid>

                                <Grid Grid.Row="4"
                                      ColumnDefinitions="140,Auto,60"
                                      ColumnSpacing="8">
                                    <Label Text="Bold"
                                           VerticalTextAlignment="Center"
                                           TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#F3EDE2}" />
                                    <Label Grid.Column="1"
                                           Text="⌘ +"
                                           VerticalTextAlignment="Center"
                                           FontSize="14"
                                           TextColor="{AppThemeBinding Light=#6A655D, Dark=#BEB7AC}" />
                                    <Entry Grid.Column="2"
                                           MaxLength="1"
                                           HorizontalTextAlignment="Center"
                                           Text="{Binding ShortcutKeyBold}" />
                                </Grid>

                                <Grid Grid.Row="5"
                                      ColumnDefinitions="140,Auto,60"
                                      ColumnSpacing="8">
                                    <Label Text="Italic"
                                           VerticalTextAlignment="Center"
                                           TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#F3EDE2}" />
                                    <Label Grid.Column="1"
                                           Text="⌘ +"
                                           VerticalTextAlignment="Center"
                                           FontSize="14"
                                           TextColor="{AppThemeBinding Light=#6A655D, Dark=#BEB7AC}" />
                                    <Entry Grid.Column="2"
                                           MaxLength="1"
                                           HorizontalTextAlignment="Center"
                                           Text="{Binding ShortcutKeyItalic}" />
                                </Grid>
                            </Grid>

                            <!-- Transcription tab -->
                            <VerticalStackLayout Spacing="14"
                                                 IsVisible="{Binding IsTranscriptionTabActive}">

                                <!-- Recording Format -->
                                <Label Text="Record new files to..."
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#F3EDE2}" />

                                <VerticalStackLayout Spacing="6">
                                    <HorizontalStackLayout Spacing="8">
                                        <RadioButton Content="M4A  (default)"
                                                     GroupName="RecordingFormat"
                                                     IsChecked="{Binding PreferencesRecordingFormat,
                                                         Converter={StaticResource EnumToBoolConverter},
                                                         ConverterParameter=M4A}" />
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="8">
                                        <RadioButton Content="MP3  (requires ffmpeg)"
                                                     GroupName="RecordingFormat"
                                                     IsChecked="{Binding PreferencesRecordingFormat,
                                                         Converter={StaticResource EnumToBoolConverter},
                                                         ConverterParameter=MP3}" />
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="8">
                                        <RadioButton Content="FLAC"
                                                     GroupName="RecordingFormat"
                                                     IsChecked="{Binding PreferencesRecordingFormat,
                                                         Converter={StaticResource EnumToBoolConverter},
                                                         ConverterParameter=FLAC}" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>

                                <!-- Transcription Engine -->
                                <Label Text="Transcription Engine"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#F3EDE2}" />

                                <VerticalStackLayout Spacing="6">
                                    <HorizontalStackLayout Spacing="8">
                                        <RadioButton Content="Apple Speech Framework"
                                                     GroupName="TranscriptionEngine"
                                                     IsChecked="{Binding PreferencesTranscriptionEngine,
                                                         Converter={StaticResource EnumToBoolConverter},
                                                         ConverterParameter=AppleSpeech}" />
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="8">
                                        <RadioButton Content="Whisper.cpp"
                                                     GroupName="TranscriptionEngine"
                                                     IsChecked="{Binding PreferencesTranscriptionEngine,
                                                         Converter={StaticResource EnumToBoolConverter},
                                                         ConverterParameter=WhisperCpp}" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>

                                <!-- Whisper paths — only shown when Whisper.cpp selected -->
                                <VerticalStackLayout Spacing="8"
                                                     IsVisible="{Binding IsWhisperCppSelected}">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="whisper-cli Binary"
                                               FontSize="12"
                                               TextColor="{AppThemeBinding Light=#6A655D, Dark=#BEB7AC}" />
                                        <Entry Placeholder="/opt/homebrew/bin/whisper-cli"
                                               Text="{Binding PreferencesWhisperBinaryPath}" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="Whisper Model File (.bin)"
                                               FontSize="12"
                                               TextColor="{AppThemeBinding Light=#6A655D, Dark=#BEB7AC}" />
                                        <Entry Placeholder="/path/to/ggml-model.bin"
                                               Text="{Binding PreferencesWhisperModelPath}" />
                                    </VerticalStackLayout>
                                </VerticalStackLayout>

                                <!-- Diarization Engine -->
                                <Label Text="Speaker Diarization Engine"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#F3EDE2}"
                                       Margin="0,6,0,0" />

                                <VerticalStackLayout Spacing="6">
                                    <HorizontalStackLayout Spacing="8">
                                        <RadioButton Content="None  (all segments labelled Unknown Speaker)"
                                                     GroupName="DiarizationEngine"
                                                     IsChecked="{Binding PreferencesDiarizationEngine,
                                                         Converter={StaticResource EnumToBoolConverter},
                                                         ConverterParameter=None}" />
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="8">
                                        <RadioButton Content="pyannote.audio 3.1"
                                                     GroupName="DiarizationEngine"
                                                     IsChecked="{Binding PreferencesDiarizationEngine,
                                                         Converter={StaticResource EnumToBoolConverter},
                                                         ConverterParameter=Pyannote}" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>

                                <!-- pyannote Python path — only shown when pyannote selected -->
                                <Grid ColumnDefinitions="*"
                                      IsVisible="{Binding IsPyannoteSelected}">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="Python Executable"
                                               FontSize="12"
                                               TextColor="{AppThemeBinding Light=#6A655D, Dark=#BEB7AC}" />
                                        <Entry Placeholder="/usr/local/bin/python3"
                                               Text="{Binding PreferencesPyannotePythonPath}" />
                                    </VerticalStackLayout>
                                </Grid>

                            </VerticalStackLayout>
                        </Grid>

                        <!-- Save/Cancel buttons always visible -->
                        <HorizontalStackLayout Grid.Row="2"
                                               Spacing="10">
                            <Button Text="Save Preferences"
                                    Command="{Binding SavePreferencesCommand}" />
                            <Button Text="Cancel"
                                    Command="{Binding CancelPreferencesCommand}" />
                        </HorizontalStackLayout>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        BackgroundColor="{AppThemeBinding Light=#E8E0CF, Dark=#32302D}"
                        Stroke="{AppThemeBinding Light=#D8D0C2, Dark=#474542}"
                        StrokeThickness="1"
                        Padding="16,12,16,12"
                        StrokeShape="RoundRectangle 18,18,0,0">
                    <HorizontalStackLayout Spacing="8">
                        <Border Padding="22,12"
                                Margin="0,4,0,0"
                                BackgroundColor="{AppThemeBinding Light=#DDD4C4, Dark=#3B3834}"
                                Stroke="{AppThemeBinding Light=#CFC4B2, Dark=#4A4743}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 16,16,0,0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SetViewModeCommand}"
                                                      CommandParameter="{x:Static models:EditorViewMode.Viewer}" />
                            </Border.GestureRecognizers>
                            <Border.Triggers>
                                <DataTrigger TargetType="Border"
                                             Binding="{Binding IsReaderMode}"
                                             Value="True">
                                    <Setter Property="Margin" Value="0,0,0,-1" />
                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#F7F2E8, Dark=#2D2E30}" />
                                    <Setter Property="Stroke" Value="{AppThemeBinding Light=#D5CCBC, Dark=#45474B}" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Label Text="Reader"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#4E483F, Dark=#D6CEC2}" />
                            <Border.Resources>
                                <Style TargetType="Label">
                                    <Style.Triggers>
                                        <DataTrigger TargetType="Label"
                                                     Binding="{Binding IsReaderMode}"
                                                     Value="True">
                                            <Setter Property="TextColor" Value="{AppThemeBinding Light=#1D1D1B, Dark=#F3EDE2}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Resources>
                        </Border>

                        <Border Padding="22,12"
                                Margin="0,4,0,0"
                                BackgroundColor="{AppThemeBinding Light=#DDD4C4, Dark=#3B3834}"
                                Stroke="{AppThemeBinding Light=#CFC4B2, Dark=#4A4743}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 16,16,0,0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SetViewModeCommand}"
                                                      CommandParameter="{x:Static models:EditorViewMode.TextEditor}" />
                            </Border.GestureRecognizers>
                            <Border.Triggers>
                                <DataTrigger TargetType="Border"
                                             Binding="{Binding IsTextEditorMode}"
                                             Value="True">
                                    <Setter Property="Margin" Value="0,0,0,-1" />
                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#F7F2E8, Dark=#2D2E30}" />
                                    <Setter Property="Stroke" Value="{AppThemeBinding Light=#D5CCBC, Dark=#45474B}" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Label Text="Text Editor"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#4E483F, Dark=#D6CEC2}" />
                            <Border.Resources>
                                <Style TargetType="Label">
                                    <Style.Triggers>
                                        <DataTrigger TargetType="Label"
                                                     Binding="{Binding IsTextEditorMode}"
                                                     Value="True">
                                            <Setter Property="TextColor" Value="{AppThemeBinding Light=#1D1D1B, Dark=#F3EDE2}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Resources>
                        </Border>

                        <Border Padding="22,12"
                                Margin="0,4,0,0"
                                BackgroundColor="{AppThemeBinding Light=#DDD4C4, Dark=#3B3834}"
                                Stroke="{AppThemeBinding Light=#CFC4B2, Dark=#4A4743}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 16,16,0,0"
                                ToolTipProperties.Text="{Binding VisualEditorUnavailableMessage}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SetViewModeCommand}"
                                                      CommandParameter="{x:Static models:EditorViewMode.RichTextEditor}" />
                            </Border.GestureRecognizers>
                            <Border.Triggers>
                                <DataTrigger TargetType="Border"
                                             Binding="{Binding IsVisualEditorMode}"
                                             Value="True">
                                    <Setter Property="Margin" Value="0,0,0,-1" />
                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#F7F2E8, Dark=#2D2E30}" />
                                    <Setter Property="Stroke" Value="{AppThemeBinding Light=#D5CCBC, Dark=#45474B}" />
                                </DataTrigger>
                                <DataTrigger TargetType="Border"
                                             Binding="{Binding IsVisualEditorSupported}"
                                             Value="False">
                                    <Setter Property="Opacity" Value="0.58" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Label Text="Visual Editor"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#4E483F, Dark=#D6CEC2}" />
                            <Border.Resources>
                                <Style TargetType="Label">
                                    <Style.Triggers>
                                        <DataTrigger TargetType="Label"
                                                     Binding="{Binding IsVisualEditorMode}"
                                                     Value="True">
                                            <Setter Property="TextColor" Value="{AppThemeBinding Light=#1D1D1B, Dark=#F3EDE2}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Resources>
                        </Border>
                    </HorizontalStackLayout>
                </Border>

                <views:ViewerHostView x:Name="ViewerHost"
                                      Grid.Row="3" />

                <views:RecordingGroupView x:Name="RecordingGroupView"
                                           Grid.Row="3"
                                           VerticalOptions="End"
                                           IsVisible="{Binding IsRecordingGroupSelected}"
                                           BindingContext="{Binding}" />

                <views:LogsDockView x:Name="LogsDock"
                                    Grid.Row="4" />
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
