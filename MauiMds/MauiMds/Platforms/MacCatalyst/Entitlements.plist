<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
    <!-- See https://aka.ms/maui-publish-app-store#add-entitlements for more information about adding entitlements.-->
    <dict>
        <!-- App Sandbox must be enabled to distribute a MacCatalyst app through the Mac App Store. -->
        <key>com.apple.security.app-sandbox</key>
        <true/>
        <!-- When App Sandbox is enabled, this value is required to open outgoing network connections. -->
        <key>com.apple.security.network.client</key>
        <true/>
        <!-- Allows reading and writing files the user explicitly chooses via the file picker. -->
        <key>com.apple.security.files.user-selected.read-write</key>
        <true/>
        <!-- Required for AVCaptureSession microphone access in the sandbox. -->
        <key>com.apple.security.device.audio-input</key>
        <true/>
        <!-- Required for ScreenCaptureKit audio capture in the sandbox. -->
        <key>com.apple.security.device.camera</key>
        <true/>
        <!-- FileSystemWatcher: in a sandboxed app, events are only delivered for paths
             inside the app container or paths covered by a security-scoped bookmark.
             Watching arbitrary user-selected folders requires the bookmark to remain
             active (StartAccessingSecurityScopedResource) for the duration of the watch.
             No additional entitlement is needed beyond files.user-selected.read-write,
             but the bookmark access scope must be held open. -->
        <!-- Subprocess execution (afconvert, ffmpeg, whisper-cli, pyannote Python):
             Spawning arbitrary processes via Process.Start() is NOT permitted in a
             Mac App Store sandbox. FLAC conversion has been migrated to native
             ExtAudioFile (no subprocess). MP3 falls back to native AAC/M4A export
             when ffmpeg is absent. Live WAV chunks (LiveAudioChunkWriter) still use
             afconvert — replace with ExtAudioFile if App Store distribution is needed.
             Whisper-cli and pyannote require out-of-process or XPC alternatives for
             a sandboxed build. -->
    </dict>
</plist>

