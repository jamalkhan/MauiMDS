<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
    <!-- See https://aka.ms/maui-publish-app-store#add-entitlements for more information about adding entitlements.-->
    <dict>
        <!-- App Sandbox must be enabled to distribute a MacCatalyst app through the Mac App Store. -->
        <key>com.apple.security.app-sandbox</key>
        <true/>
        <!-- When App Sandbox is enabled, this value is required to open outgoing network connections. -->
        <key>com.apple.security.network.client</key>
        <true/>
        <!-- Allows reading and writing files the user explicitly chooses via the file picker. -->
        <key>com.apple.security.files.user-selected.read-write</key>
        <true/>
        <!-- Required for AVCaptureSession microphone access in the sandbox. -->
        <key>com.apple.security.device.audio-input</key>
        <true/>
        <!-- Required for ScreenCaptureKit audio capture in the sandbox. -->
        <key>com.apple.security.device.camera</key>
        <true/>
        <!-- Required to create and resolve security-scoped bookmarks that persist
             across app relaunches. Without this entitlement, NSUrl.CreateBookmarkData
             with WithSecurityScope may succeed but the bookmark will be unresolvable
             after the next launch. Covers workspace folders and any user-selected files
             that the app needs to reopen without showing a new file picker. -->
        <key>com.apple.security.files.bookmarks.app-scope</key>
        <true/>
        <!-- FileSystemWatcher: in a sandboxed app, events are only delivered for paths
             inside the app container or paths covered by a security-scoped bookmark.
             Watching arbitrary user-selected folders requires the bookmark to remain
             active (StartAccessingSecurityScopedResource) for the duration of the watch.
             No additional entitlement is needed beyond files.user-selected.read-write
             and files.bookmarks.app-scope, but the bookmark access scope must be held
             open for the lifetime of the watcher. -->
        <!-- Subprocess execution (whisper-cli, pyannote Python):
             FLAC conversion uses native ExtAudioFile (no subprocess).
             MP3 uses native AVAssetExportSession → AAC/M4A (no subprocess).
             Live WAV chunks use native ExtAudioFile for M4A→WAV conversion (no subprocess).
             Remaining subprocess callers: whisper-cli (WhisperCppTranscriptionEngine) and
             pyannote Python (PyannoteDiarizationEngine). These require either an XPC service
             or replacement with Apple Speech / CoreML for Mac App Store distribution. -->
    </dict>
</plist>

